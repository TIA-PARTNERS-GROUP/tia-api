											],
											"type": "object"
										}
									]
								}
							}
						}
					},
					"401": {
						"description": "Invalid authentication token"
					}
				},
				"description": "User Logout\n\nRevokes the current authentication session, invalidating the JWT token.\nPrevents further use of the token for authenticated requests.",
				"summary": "Logout and revoke current session",
				"tags": [
					"Authentication"
				],
				"security": [
					{
						"BearerAuth": []
					}
				],
				"parameters": []
			}
		},
		"/auth/logout-all": {
			"post": {
				"operationId": "LogoutAll",
				"responses": {
					"200": {
						"description": "All sessions ended",
						"content": {
							"application/json": {
								"schema": {
									"anyOf": [

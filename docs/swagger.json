					"401": {
						"description": "Invalid authentication token"
					}
				},
				"description": "Get Active Sessions\n\nRetrieves all active sessions for the authenticated user. Useful for\nmanaging multiple devices and monitoring account security.",
				"summary": "Get user's active sessions",
				"tags": [
					"Authentication"

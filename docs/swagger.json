	"paths": {
		"/auth/login": {
			"post": {
				"operationId": "Login",
				"responses": {
					"200": {
						"description": "Login successful",
						"content": {
							"application/json": {
								"schema": {
									"anyOf": [
										{
											"$ref": "#/components/schemas/LoginResponse"
										},
										{
											"properties": {
												"details": {},
												"message": {
													"type": "string"
												}
											},
											"required": [
												"message"
											],
											"type": "object"
										}
									]
								},
								"examples": {
									"Example 1": {
										"value": {
											"login_email": "jane.doe@example.com",
											"password": "SecurePassword123!"
										}
									}
								}
							}
						}
					},
					"401": {
						"description": "Invalid credentials"
					},
					"422": {
						"description": "Validation failed"
					}
				},
				"description": "User Login\n\nAuthenticates user credentials and creates a new session. Returns a JWT token\nfor subsequent authenticated requests. Sessions are tracked with IP and user agent.",
				"summary": "Authenticate user and create session",
				"tags": [
					"Authentication"
				],
				"security": [],
				"parameters": [
					{
						"in": "header",
						"name": "user-agent",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "header",
						"name": "x-forwarded-for",
						"required": false,
						"schema": {
							"type": "string"
						}
					}
				],
				"requestBody": {
					"description": "User login credentials",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/LoginRequest",
								"description": "User login credentials"
							},
							"example": {
								"login_email": "jane.doe@example.com",
								"password": "SecurePassword123!"
							}
						}
					}
				}
			}
		},
		"/auth/logout": {
			"post": {
				"operationId": "Logout",
				"responses": {
					"200": {
						"description": "Logout successful",
						"content": {
							"application/json": {
								"schema": {
									"anyOf": [
										{
											"$ref": "#/components/schemas/LogoutResponse"
										},
										{
											"properties": {
												"message": {
													"type": "string"
												}
											},
											"required": [
												"message"
											],
											"type": "object"
										}
									]
								}
							}
						}
					},
					"401": {
						"description": "Invalid authentication token"
					}
				},
				"description": "User Logout\n\nRevokes the current authentication session, invalidating the JWT token.\nPrevents further use of the token for authenticated requests.",
				"summary": "Logout and revoke current session",
				"tags": [
					"Authentication"
				],
				"security": [
					{
						"BearerAuth": []
					}
				],
				"parameters": []
			}
		},
		"/auth/logout-all": {
			"post": {
				"operationId": "LogoutAll",
				"responses": {
					"200": {
						"description": "All sessions ended",
						"content": {
							"application/json": {
								"schema": {
									"anyOf": [
										{
											"$ref": "#/components/schemas/LogoutResponse"
										},
										{
											"properties": {
												"message": {
													"type": "string"
												}
											},
											"required": [
												"message"
											],
											"type": "object"
										}
									]
								}
							}
						}
					},
					"401": {
						"description": "Invalid authentication token"
					}
				},
				"description": "Logout All Sessions\n\nRevokes all active sessions for the authenticated user across all devices.\nUseful for security incidents or when changing passwords.",
				"summary": "Logout from all devices",
				"tags": [
					"Authentication"
				],
				"security": [
					{
						"BearerAuth": []
					}
				],
				"parameters": []
			}
		},
		"/auth/validate": {
			"get": {
				"operationId": "ValidateToken",
				"responses": {
					"200": {
						"description": "Token is valid",
						"content": {
							"application/json": {
								"schema": {
									"anyOf": [
										{
											"$ref": "#/components/schemas/TokenValidationResponse"
										},
										{
											"properties": {
												"message": {
													"type": "string"
												}
											},
											"required": [
												"message"
											],
											"type": "object"
										}
									]
								}
							}
						}
					},
					"401": {
						"description": "Invalid or expired token"
					}
				},
				"description": "Validate Token\n\nValidates the current JWT token and returns user information if valid.\nUseful for checking token expiration and user status.",
				"summary": "Validate authentication token",
				"tags": [
					"Authentication"
				],
				"security": [
					{
						"BearerAuth": []
					}
				],
				"parameters": []
			}
		},

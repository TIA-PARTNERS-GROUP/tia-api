					},
					"422": {
						"description": "Validation Failed"
					}
				},
				"description": "Update User Account\n\nUpdates an existing user's account information. Supports partial updates where\nonly provided fields are modified. Password updates are automatically hashed.",
				"summary": "Update user account",
				"tags": [
					"Users"
				],
				"security": [],
				"parameters": [
					{
						"description": "User's unique identifier",
						"in": "path",
						"name": "id",
						"required": true,
						"schema": {
							"format": "double",
							"type": "number"
						},
						"example": 123
					}
				],
				"requestBody": {
					"description": "Fields to update (partial update supported)",
					"required": true,
					"content": {

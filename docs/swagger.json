							}
						}
					}
				},
				"description": "Retrieve All Users\n\nReturns a paginated list of all registered users in the system.",
				"summary": "Get all users",
				"tags": [
					"Users"
				],
				"security": [],
				"parameters": []
			},
			"post": {
				"operationId": "CreateUser",
				"responses": {
					"201": {
						"description": "Created",
						"content": {
							"application/json": {
								"schema": {
									"anyOf": [
										{
											"$ref": "#/components/schemas/UserResponse"
										},
										{
											"properties": {
												"details": {},
												"message": {
													"type": "string"
												}
											},
											"required": [
												"message"
											],
											"type": "object"
										}
									]
								},
								"examples": {
									"Example 1": {
										"value": {
											"first_name": "Jane",
											"last_name": "Doe",
											"login_email": "jane.doe@example.com",
											"password": "SecurePassword123!",
											"contact_email": "jane.contact@example.com",
											"contact_phone_no": "0455454321",
											"adk_session_id": "123e4567-e89b-12d3-a456-426614174000"
										}
									}
								}
							}
						}
					},
					"409": {
						"description": "Email already exists"
					},
					"422": {
						"description": "Validation Failed"
					}
				},
				"description": "Create New User\n\nRegisters a new user in the system. Creates a user account with the provided\nprofile information and securely hashes the password before storage.",
				"summary": "Create a new user",
				"tags": [
					"Users"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"description": "User registration data",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/UserCreateRequest",
								"description": "User registration data"
							},
							"example": {
								"first_name": "Jane",
								"last_name": "Doe",
								"login_email": "jane.doe@example.com",
								"password": "SecurePassword123!",
								"contact_email": "jane.contact@example.com",
								"contact_phone_no": "0455454321",
								"adk_session_id": "123e4567-e89b-12d3-a456-426614174000"
							}
						}
					}
				}
			}
		},
		"/users/{id}": {
			"get": {
				"operationId": "GetUserById",
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"application/json": {
								"schema": {
									"allOf": [
										{
											"$ref": "#/components/schemas/UserResponse"
										}
									],
									"nullable": true
								}
							}
						}
					},
					"404": {
						"description": "Not Found"
					}
				},
				"description": "Get User by ID\n\nRetrieves detailed information for a specific user by their unique identifier.\nReturns complete user profile including contact information and account status.",
				"summary": "Get user by ID",
				"tags": [
					"Users"
				],
				"security": [],
				"parameters": [
					{
						"description": "User's unique identifier (positive integer)",
						"in": "path",
						"name": "id",
						"required": true,
						"schema": {
							"format": "double",
							"type": "number"
						},
						"example": 123
					}
				]
			},
			"put": {
				"operationId": "UpdateUser",
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"application/json": {
								"schema": {
									"anyOf": [
										{
											"$ref": "#/components/schemas/UserResponse"
										},
										{
											"properties": {
												"details": {},
												"message": {
													"type": "string"
												}
											},
											"required": [
												"message"
											],
											"type": "object"
										}
									]
								},
								"examples": {
									"Example 1": {
										"value": {
											"first_name": "Jane",
											"last_name": "Smith",
											"login_email": "jane.smith@example.com",
											"password": "NewSecurePassword456!",
											"contact_email": "jane.smith@example.com",
											"contact_phone_no": "0455454321",
											"email_verified": true,
											"active": true
										}
									}

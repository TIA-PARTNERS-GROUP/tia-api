					}
				},
				"description": "Validate Token\n\nValidates the current JWT token and returns user information if valid.\nUseful for checking token expiration and user status.",
				"summary": "Validate authentication token",
				"tags": [
					"Authentication"
				],
				"security": [
					{
						"BearerAuth": []
					}
				],
				"parameters": []
			}
		},

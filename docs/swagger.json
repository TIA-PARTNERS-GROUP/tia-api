										}
									]
								}
							}
						}
					},
					"401": {
						"description": "Invalid authentication token"
					}
				},
				"description": "Logout All Sessions\n\nRevokes all active sessions for the authenticated user across all devices.\nUseful for security incidents or when changing passwords.",
				"summary": "Logout from all devices",
				"tags": [
					"Authentication"
				],
				"security": [
					{
						"BearerAuth": []
					}
				],
				"parameters": []
			}
		},
		"/auth/validate": {
			"get": {
